generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  password_hash  String
  role           Role            @default(STUDENT)
  created_at     DateTime        @default(now())
  updated_at     DateTime        @updatedAt
  certificates   Certificate[]
  enrollments    Enrollment[]
  payments       Payment[]
  refresh_tokens RefreshToken[]
  video_progress VideoProgress[]
  chat_sessions  ChatSession[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  token_hash String    @db.VarChar(512)
  user_id    String
  expires_at DateTime
  revoked_at DateTime?
  created_at DateTime  @default(now())
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token_hash])
  @@map("refresh_tokens")
}

model Subject {
  id            String        @id @default(uuid())
  title         String
  slug          String        @unique
  description   String?       @db.Text
  thumbnail_url String?
  price         Decimal?      @db.Decimal(10, 2)
  is_published  Boolean       @default(false)
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
  certificates  Certificate[]
  enrollments   Enrollment[]
  payments      Payment[]
  sections      Section[]

  @@map("subjects")
}

model Section {
  id          String   @id @default(uuid())
  title       String
  subject_id  String
  order_index Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  subject     Subject  @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  videos      Video[]

  @@unique([subject_id, order_index])
  @@index([subject_id])
  @@map("sections")
}

model Video {
  id               String          @id @default(uuid())
  title            String
  description      String?         @db.Text
  youtube_url      String
  section_id       String
  order_index      Int
  duration_seconds Int             @default(0)
  is_published     Boolean         @default(false)
  thumbnail_url    String?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  progress         VideoProgress[]
  section          Section         @relation(fields: [section_id], references: [id], onDelete: Cascade)

  @@unique([section_id, order_index])
  @@index([section_id])
  @@map("videos")
}

model Enrollment {
  id         String   @id @default(uuid())
  user_id    String
  subject_id String
  created_at DateTime @default(now())
  subject    Subject  @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, subject_id])
  @@index([user_id])
  @@index([subject_id])
  @@map("enrollments")
}

model VideoProgress {
  id                    String    @id @default(uuid())
  user_id               String
  video_id              String
  last_position_seconds Int       @default(0)
  is_completed          Boolean   @default(false)
  completed_at          DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  video                 Video     @relation(fields: [video_id], references: [id], onDelete: Cascade)

  @@unique([user_id, video_id])
  @@index([user_id])
  @@index([video_id])
  @@map("video_progress")
}

model Payment {
  id             String        @id @default(uuid())
  user_id        String
  subject_id     String
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("INR")
  status         PaymentStatus @default(PENDING)
  payment_method String?
  transaction_id String?       @unique
  failure_reason String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  subject        Subject       @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([subject_id])
  @@map("payments")
}

model Certificate {
  id         String   @id @default(uuid())
  user_id    String
  subject_id String
  issued_at  DateTime @default(now())
  subject    Subject  @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, subject_id])
  @@index([user_id])
  @@index([subject_id])
  @@map("certificates")
}

model ChatSession {
  id         String        @id @default(uuid())
  user_id    String
  title      String?
  type       AssistantType @default(LEARNER)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt
  user       User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages   ChatMessage[]

  @@index([user_id])
  @@map("chat_sessions")
}

model ChatMessage {
  id         String      @id @default(uuid())
  session_id String
  role       MessageRole
  content    String      @db.Text
  created_at DateTime    @default(now())
  session    ChatSession @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
  @@map("chat_messages")
}

enum Role {
  STUDENT
  ADMIN
}

enum AssistantType {
  LEARNER
  ADMIN
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
